datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        String    @id
  name      String
  email     String    @unique
  password  String
  role      String    @default("admin")
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id        String    @id
  name      String
  email     String    @unique
  password  String?
  googleId  String?
  avatar    String?
  role      String    @default("user")
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
}

model Category {
  id          String     @id
  name        String
  slug        String     @unique
  icon        String     @default("🥟")
  description String     @default("")
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  menuItems   MenuItem[]
}

model MenuItem {
  id           String      @id
  name         String
  description  String      @default("")
  price        Float
  image        String      @default("")
  isBestSeller Boolean     @default(false)
  isAvailable  Boolean     @default(true)
  stock        Int         @default(100)
  totalOrdered Int         @default(0)
  tags         String[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  categories   Category[]
  orderItems   OrderItem[]
}

model Table {
  id             String   @id
  number         String   @unique
  name           String   @default("")
  capacity       Int      @default(4)
  qrCode         String   @default("")
  isActive       Boolean  @default(true)
  status         String   @default("available")
  currentOrderId String?  @unique
  currentOrder   Order?   @relation("TableCurrentOrder", fields: [currentOrderId], references: [id])
  orders         Order[]  @relation("TableOrders")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id              String      @id
  orderNumber     String?     @unique
  type            String
  status          String      @default("pending")
  subtotal        Float
  tax             Float       @default(0)
  total           Float
  paymentMethod   String      @default("cash")
  paymentStatus   String      @default("unpaid")
  midtransId      String?
  snapToken       String?
  snapRedirectUrl String?
  tableNumber     String?
  tableId         String?
  table           Table?      @relation("TableOrders", fields: [tableId], references: [id])
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  customerName    String      @default("Guest")
  customerEmail   String      @default("")
  customerPhone   String      @default("")
  customerAddress String      @default("")
  customerNotes   String      @default("")
  estimatedTime   Int         @default(15)
  items           OrderItem[]
  currentForTable Table?      @relation("TableCurrentOrder")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id         String   @id
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  name       String
  price      Float
  quantity   Int
  subtotal   Float
  notes      String   @default("")
}

model StoreSettings {
  id             String   @id @default("default")
  storeName      String   @default("Dimsum Ratu")
  logo           String   @default("/logo.png")
  address        String   @default("Karawang Barat, Jawa Barat, Indonesia")
  operatingHours String   @default("Setiap Hari: 10.00 – 21.00 WIB")
  contact        String   @default("0878-7131-0560")
  instagram      String   @default("@dimsumratu")
  mapUrl         String   @default("https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d63447.39099520374!2d107.27120727889587!3d-6.334154474228071!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e6977baaaffcbfd%3A0x6d3a08c27370d633!2sDimsum%20Ratu%20Oishii!5e0!3m2!1sid!2sid!4v1772400307613!5m2!1sid!2sid")
  facebookUrl    String   @default("#")
  instagramUrl   String   @default("#")
  tiktokUrl      String   @default("#")
  heroTitle      String   @default("Dimsum Lezat, Siap Dinikmati!")
  heroDesc       String   @default("Cita rasa dimsum autentik khas China Town, kini hadir di Karawang. Dine-in nyaman, take away praktis, atau delivery langsung ke pintu Anda.")
  heroImage      String   @default("/images/hero.png")
  stat1Val       String   @default("500+")
  stat1Label     String   @default("Pelanggan Puas")
  stat2Val       String   @default("4.9★")
  stat2Label     String   @default("Rating Google")
  stat3Val       String   @default("20+")
  stat3Label     String   @default("Varian Menu")
  feat1Title     String   @default("Bahan Segar Harian")
  feat1Desc      String   @default("Dipilih setiap pagi, disajikan fresh untuk rasa terbaik")
  feat2Title     String   @default("Koki Berpengalaman")
  feat2Desc      String   @default("Resep tradisional autentik dari koki berpengalaman 15+ tahun")
  feat3Title     String   @default("Delivery Cepat")
  feat3Desc      String   @default("Pengiriman dalam 30-60 menit ke seluruh area Karawang")
  feat4Title     String   @default("Bayar Mudah")
  feat4Desc      String   @default("Transfer, QRIS, atau bayar di tempat — semua bisa!")
  step1Title     String   @default("Pilih Menu")
  step1Desc      String   @default("Browse menu lengkap kami, pilih favorit Anda sesuka hati")
  step2Title     String   @default("Tambah Keranjang")
  step2Desc      String   @default("Klik tombol + lalu sesuaikan jumlah dan catatan pesanan")
  step3Title     String   @default("Konfirmasi & Bayar")
  step3Desc      String   @default("Pilih metode bayar, pesanan langsung kami proses secepatnya")
  ctaTitle       String   @default("Siap Menikmati Dimsum Terbaik?")
  ctaDesc        String   @default("Kunjungi kami atau pesan delivery sekarang. Kami melayani dengan sepenuh hati!")
  colorTheme     String   @default("red")
  taxRate        Float    @default(10.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Testimonial {
  id        String   @id
  name      String
  role      String
  text      String
  rating    Int      @default(5)
  avatar    String   @default("👩")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
